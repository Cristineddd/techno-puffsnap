# ═══════════════════════════════════════════════════════════════════════
# PUFFSNAP — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════════

# ── EmailJS (emailjs.com) ─────────────────────────────────────────────
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_USER_ID=xxxxxxxxxxxxxx

# ── Sender branding ──────────────────────────────────────────────────
# Display name the recipient sees (e.g. "PUFFSNAP Photobooth")
VITE_SENDER_NAME=PUFFSNAP Photobooth

# Reply-to email — when the recipient clicks "Reply", it goes here
# To make the FROM address show as puffsnap@gmail.com:
#   Option A: Connect puffsnap@gmail.com as your EmailJS Gmail service
#   Option B: Add puffsnap@gmail.com as a Gmail alias in your personal account
#             (Gmail → Settings → Accounts → Send mail as → Add another address)
VITE_EMAILJS_REPLY_TO=puffsnap@gmail.com
